      <aliases enabled='yes' />
      <column datatype='integer' name='[Availability]' role='measure' type='quantitative' />
      <column caption='Inventory Turnover' datatype='real' name='[Calculation_0313685051027456]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IIF([Stock levels]!=0, [Number of products sold]/[Stock levels], 0)' />
      </column>
      <column caption='Revenue per Unit Sold' datatype='real' name='[Calculation_0313685051203585]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IIF([Number of products sold]!=0, [Revenue generated]/[Number of products sold],0)' />
      </column>
      <column caption='Profit' datatype='real' default-format='c&quot;$&quot;#,##0,.00K;(&quot;$&quot;#,##0,.00K)' name='[Calculation_0313685051486210]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Revenue generated] - [Costs]' />
      </column>
      <column caption='Profit Margin' datatype='real' default-format='n#,##0.0;-#,##0.0' name='[Calculation_0313685053145091]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IIF([Revenue generated]!=0, [Calculation_0313685051486210]/[Revenue generated],0)' />
      </column>
      <column caption='Sales to Production Ratio' datatype='real' name='[Calculation_0313685053419524]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IIF([Production volumes]!=0, [Number of products sold]/[Production volumes],0)' />
      </column>
      <column caption='Stock Risk' datatype='string' name='[Calculation_0313685053628421]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IIF([Stock levels] &lt; [Order quantities], &apos;Risk&apos;, &apos;Safe&apos;)' />
      </column>
      <column datatype='real' default-format='c&quot;$&quot;#,##0,K;(&quot;$&quot;#,##0,K)' name='[Costs]' role='measure' type='quantitative' />
      <column datatype='string' name='[Customer demographics]' role='dimension' type='nominal' />
      <column datatype='date' name='[Date]' role='dimension' type='ordinal' />
      <column aggregation='None' caption='Defect rates (1 to 5)' datatype='integer' name='[Defect rates (bin) 2]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='0' formula='[Defect rates]' peg='0' size='1' />
      </column>
      <column aggregation='None' datatype='integer' name='[Defect rates (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='-1' formula='[Defect rates]' peg='0' size='0.125' />
      </column>
      <column datatype='real' default-format='n#,##0.00;-#,##0.00' name='[Defect rates]' role='measure' type='quantitative' />
      <column datatype='integer' default-format='n#,##0;-#,##0' name='[Lead time]' role='measure' type='quantitative' />
      <column datatype='real' default-format='c&quot;$&quot;#,##0;(&quot;$&quot;#,##0)' name='[Manufacturing costs]' role='measure' type='quantitative' />
      <column datatype='integer' name='[Manufacturing lead time]' role='measure' type='quantitative' />
